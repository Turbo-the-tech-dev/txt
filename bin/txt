#!/usr/bin/env node
/**
 * txt CLI v0.2.1 - YAML Package Powered, Streaming, Production-Ready
 * Master Turbo's Text Parser/Filter/Transformer/Validator
 * Uses modular src/ handlers with streaming (O(1) mem for GB files)
 * Usage: txt parse|filter|transform|validate input.txt [--type=upper] [--config=config.yaml] [-o out.txt]
 */

const path = require('path');

const VERSION = '0.2.1';

const logger = {
  info: m => console.log(`[INFO] ${m}`),
  error: m => { console.error(`[ERROR] ${m}`); process.exit(1); },
  warn: m => console.warn(`[WARN] ${m}`),
};

function parseArgs(argv) {
  const args = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a.startsWith('--')) args[a.slice(2)] = argv[i + 1] && !argv[i + 1].startsWith('-') ? argv[++i] : true;
    else if (a.startsWith('-') && a.length > 1) args[a.slice(1)] = argv[i + 1] && !argv[i + 1].startsWith('-') ? argv[++i] : true;
    else args._.push(a);
  }
  return args;
}

// Use full YAML parser from utils (yaml package powered)
function loadConfig(file) {
  if (!file) return { filters: ['trim'] };
  const { loadConfig } = require('../src/utils/config');
  return loadConfig(file);
}

// Commands - delegate to modular src/ handlers
async function cmdParse(args) {
  const { parse } = require('../src/parser');
  await parse(args);
}

async function cmdFilter(args) {
  const { filter } = require('../src/filters');
  await filter(args);
}

async function cmdTransform(args) {
  const { transform } = require('../src/transform');
  await transform(args);
}

async function cmdValidate(args) {
  const { validate } = require('../src/validate');
  await validate(args);
}

async function cmdSearch(args) {
  const { search } = require('../src/filters');
  await search(args);
}

async function cmdNumber(args) {
  const { numberLines } = require('../src/filters');
  await numberLines(args);
}

async function cmdCount(args) {
  const { count } = require('../src/count');
  await count(args);
}

async function cmdStats(args) {
  const { stats } = require('../src/count');
  await stats(args);
}

async function cmdDuplicates(args) {
  const { findDuplicates } = require('../src/count');
  await findDuplicates(args);
}

// Fallback inline implementations for standalone mode
const FILTERS = {
  uppercase: t => t.toUpperCase(),
  lowercase: t => t.toLowerCase(),
  trim: t => t.trim(),
  trimLeft: t => t.trimStart(),
  trimRight: t => t.trimEnd(),
  reverse: t => t.split('').reverse().join(''),
  base64: t => Buffer.from(t).toString('base64'),
  debase64: t => Buffer.from(t, 'base64').toString(),
};

async function processStreamInline(inputPath, processor, outputPath) {
  const fs = require('fs');
  const readline = require('readline');
  
  return new Promise((res, rej) => {
    const input = inputPath === '-' ? process.stdin : fs.createReadStream(inputPath);
    const rl = readline.createInterface({ input, crlfDelay: Infinity });
    const outStream = outputPath ? fs.createWriteStream(outputPath) : process.stdout;
    let lineCount = 0;

    rl.on('line', line => {
      const processed = processor(line);
      outStream.write(processed + '\n');
      lineCount++;
    });
    rl.on('close', () => {
      if (outputPath) outStream.end();
      logger.info(`Processed ${lineCount} lines`);
      res();
    });
    rl.on('error', rej);
  });
}

async function cmdFilterInline(args) {
  const input = args._[1] || '-';
  const out = args.o || args.output;
  const types = (args.type || args.t || 'trim').split(',').map(t => t.trim());
  const proc = line => types.reduce((acc, f) => FILTERS[f] ? FILTERS[f](acc) : acc, line);
  await processStreamInline(input, proc, out);
}

async function cmdTransformInline(args) {
  const input = args._[1] || '-';
  const out = args.o || args.output;
  const cfg = loadConfig(args.config || args.c);
  const filterNames = cfg.filters || ['trim'];
  const proc = line => filterNames.reduce((acc, f) => FILTERS[f] ? FILTERS[f](acc) : acc, line);
  await processStreamInline(input, proc, out);
}

async function cmdValidateInline(args) {
  const input = args._[1] || '-';
  const out = args.o || args.output;
  const schemaRegex = args.regex ? new RegExp(args.regex) : /.+/;
  const proc = line => schemaRegex.test(line) ? line : '';
  await processStreamInline(input, proc, out);
}

function showHelp() {
  console.log(`
txt v${VERSION} - Elite Text CLI (streaming, zero-mem)

Usage: txt <command> [input] [options]

Commands:
  parse       Parse → structured lines/stats
  filter      Apply filters (--type=upper,trim,reverse...)
  transform   YAML-driven transform (--config=config.yaml)
  validate    Schema validation (--regex=^\\d+)
  help        This help

Options:
  -o, --output <file>   Write to file
  -c, --config <file>   YAML config
  -v, --version         Show version

Examples:
  txt parse log.txt -o out.jsonl
  txt filter --type uppercase,trim error.log
  txt transform --config rules.yaml input.txt
`);
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  if (args.h || args.help) return showHelp();
  if (args.v || args.version) return console.log(`txt v${VERSION}`);

  const cmd = args._[0];
  if (!cmd) {
    showHelp();
    process.exit(1);
  }
  
  // Try modular handlers first, fall back to inline
  try {
    switch (cmd) {
      case 'parse': await cmdParse(args); break;
      case 'filter': await cmdFilter(args); break;
      case 'transform': await cmdTransform(args); break;
      case 'validate': await cmdValidate(args); break;
      case 'search': await cmdSearch(args); break;
      case 'number': await cmdNumber(args); break;
      case 'count': await cmdCount(args); break;
      case 'stats': await cmdStats(args); break;
      case 'duplicates': await cmdDuplicates(args); break;
      case 'help': showHelp(); break;
      default: logger.error(`Unknown command: ${cmd}`); showHelp(); process.exit(1);
    }
  } catch (e) {
    // Fall back to inline implementations
    try {
      switch (cmd) {
        case 'filter': await cmdFilterInline(args); break;
        case 'transform': await cmdTransformInline(args); break;
        case 'validate': await cmdValidateInline(args); break;
        default: throw e;
      }
    } catch (e2) {
      logger.error(e2.message);
      if (args.verbose) console.error(e2.stack);
      process.exit(1);
    }
  }
}

if (require.main === module) main();
module.exports = { main, FILTERS }; // for tests
